{
  "name": "aboleon/metaframework-codex",
  "description": "Reusable Codex agent rules for Laravel and Aboleon MetaFramework applications",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "codex",
    "agents",
    "laravel",
    "metaframework",
    "svelte"
  ],
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "Aboleon\\MetaFrameworkCodex\\": "src/"
    }
  },
  "bin": [
    "bin/mfw-codex-agents"
  ],
  "archive": {
    "exclude": [
      "/.idea"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
